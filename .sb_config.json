{
    "version": "1.0",
    "laziness": {
        "gates": {
            "dead-code.py": {
                "enabled": true,
                "min_confidence": 60
            }
        }
    },
    "overconfidence": {
        "gates": {
            "untested-code.py": {
                "enabled": true,
                "test_dirs": ["tests"]
            }
        }
    },
    "deceptiveness": {
        "gates": {
            "bogus-tests.py": {
                "enabled": true
            }
        }
    },
    "myopia": {
        "gates": {
            "source-duplication": {
                "enabled": false,
                "threshold": 5
            },
            "string-duplication.py": {
                "enabled": true,
                "threshold": 2,
                "min_words": 3
            }
        }
    }
}
